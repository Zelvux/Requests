{
  "name": "Approve-All-JoinRequests",
  "description": "Approve all pending join requests on your telegram channel using user session (Pyrogram v2)",
  "keywords": [
    "telegram",
    "pyrogram",
    "userbot",
    "join-requests"
  ],
  "repository": "https://github.com/MrMKN/Approve-All-JoinRequests",
  "env": {
